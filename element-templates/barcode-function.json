{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Barcode function",
  "id": "io.camunda.connector.barcode.BarcodeFunction",
  "description": "Generate a barcode from a code and a barcode format",
  "documentationRef": "https://docs.camunda.io/docs/components/modeler/web-modeler/connectors/available-connectors/template/",
  "icon": {
    "contents": "data:image/png;base64,\u003d"
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "Input",
      "label": "Input"
    },
    {
      "id": "Output",
      "label": "Output"
    }
  ],
  "properties": [
    {
      "binding": {
        "type": "zeebe:taskDefinition:type"
      },
      "type": "Hidden",
      "value": "c-barcode-function"
    },
    {
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "Hidden",
      "value": "result"
    },
    {
      "id": "code",
      "label": "Code",
      "description": "Code",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "code",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "barcodeFormat",
      "label": "Barcode Format",
      "description": "Barcode format",
      "type": "Dropdown",
      "choices": [
        {
          "name": "AZTEC",
          "value": "AZTEC"
        },
        {
          "name": "CODABAR",
          "value": "CODABAR"
        },
        {
          "name": "CODE_128",
          "value": "CODE_128"
        },
        {
          "name": "CODE_39",
          "value": "CODE_39"
        },
        {
          "name": "CODE_93",
          "value": "CODE_93"
        },
        {
          "name": "DATA_MATRIX",
          "value": "DATA_MATRIX"
        },
        {
          "name": "EAN_13",
          "value": "EAN_13"
        },
        {
          "name": "EAN_8",
          "value": "EAN_8"
        },
        {
          "name": "ITF",
          "value": "ITF"
        },
        {
          "name": "MAXICODE",
          "value": "MAXICODE"
        },
        {
          "name": "PDF_417",
          "value": "PDF_417"
        },
        {
          "name": "QR_CODE",
          "value": "QR_CODE"
        },
        {
          "name": "RSS_14",
          "value": "RSS_14"
        },
        {
          "name": "RSS_EXPANDED",
          "value": "RSS_EXPANDED"
        },
        {
          "name": "UPC_A",
          "value": "UPC_A"
        },
        {
          "name": "UPC_E",
          "value": "UPC_E"
        },
        {
          "name": "UPC_EAN_EXTENSION",
          "value": "UPC_EAN_EXTENSION"
        }
      ],
      "binding": {
        "name": "barcodeFormat",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "outputFormat",
      "label": "Output format",
      "description": "Output format",
      "type": "Dropdown",
      "choices": [
        {
          "name": "PNG",
          "value": "PNG"
        },
        {
          "name": "JPEG",
          "value": "JPEG"
        },
        {
          "name": "BMP",
          "value": "BMP"
        },
        {
          "name": "GIFPNG",
          "value": "GIFPNG"
        },
        {
          "name": "WBPM",
          "value": "WBPM"
        }
      ],
      "binding": {
        "name": "outputFormat",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "destinationFileName",
      "label": "Destination file name",
      "description": "Name of the new file created",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "destinationFileName",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "destinationJsonStorageDefinition",
      "label": "JSon Storage Destination",
      "description": "Storage Definition in Json.",
      "type": "String",
      "feel": "optional",
      "binding": {
        "name": "destinationJsonStorageDefinition",
        "type": "zeebe:input"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Input"
    },
    {
      "id": "destinationFile",
      "label": "Destination variable name",
      "description": "Process variable where the file reference is saved",
      "type": "String",
      "feel": "optional",
      "binding": {
        "source": "\u003d result.destinationFile",
        "type": "zeebe:output"
      },
      "constraints": {
        "notEmpty": true
      },
      "group": "Output"
    },
    {
      "label": "ControllerPage Expression",
      "description": "Expression to define BPMN Errors to throw",
      "type": "Hidden",
      "value": "if is defined(error) then bpmnError(error.code, error.message) else null",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      }
    }
  ]
}